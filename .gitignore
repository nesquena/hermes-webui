# =============================================================================
# Neo WebUI — .gitignore
# Fork de nesquena/hermes-webui com customizações para o agente Neo.
# Organizado por categoria. Manter alfabético dentro de cada seção.
# =============================================================================

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.eggs/
dist/
build/
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ─── Virtual environments ────────────────────────────────────────────────────
.venv/
venv/
env/
.python-version

# ─── Environment and secrets ─────────────────────────────────────────────────
# Keep the example template; ignore everything else.
.env
.env.*
!.env.example

# ─── AI coding assistants / IDE agent configs ────────────────────────────────
.claude/
CLAUDE.md
AGENTS.md
.cursorrules
.cursor/
.windsurfrules
.aider*
copilot-instructions.md
.continue/
.codeium/

# ─── Editors and IDEs ────────────────────────────────────────────────────────
.idea/
.vscode/
*.code-workspace
*.sublime-project
*.sublime-workspace

# ─── OS files ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ─── Generated / build artifacts ────────────────────────────────────────────
api/_version.py

# ─── Design mockups and screenshots (reference only, not served) ─────────────
static/neo_agent_web_ui.png
screenshot-*.png
full-UI.png

# ─── Archive and backups ─────────────────────────────────────────────────────
archive/
*.bak
*.orig

# ─── Local-only PR review harness ────────────────────────────────────────────
.local-review/
graphify-out/
.graphify_cached.json
.graphify_uncached.txt

# ─── Node.js (for MCP servers / bridge dev) ──────────────────────────────────
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/

# ─── Docker (local dev) ──────────────────────────────────────────────────────
.docker/

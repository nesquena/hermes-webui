{
  "id": "chat-tiling",
  "name": "Chat Tiling",
  "description": "Multi-session tiling layouts for Hermes WebUI. Split the chat into 2, 4, or 6 independent tiles — each with its own session, composer state, and streaming. Click sessions from the sidebar to fill tiles.",
  "version": "0.1.0",
  "author": "ChonSong",
  "homepage": "https://github.com/ChonSong/hermes-webui",
  "assets": {
    "scripts": ["assets/tiling.js"],
    "stylesheets": ["assets/tiling.css"]
  },
  "capabilities": ["manifest-bundle"],
  "lifecycle": {
    "webui_restart_required": false,
    "sidecar_start_required": false,
    "native_host_start_required": false,
    "native_host_autostart": "none"
  },
  "permissions": {
    "webui_api": {
      "read": ["session", "sessions"],
      "write": []
    },
    "webui_navigation": false,
    "dom": {
      "owned": true,
      "mutates_core_views": true
    },
    "storage": {
      "owned": ["hermes-ext-chat-tiling"],
      "shared_webui_keys": []
    },
    "loopback_sidecar": false,
    "native_host": false,
    "filesystem": {
      "arbitrary": false,
      "serves_bundled_assets": true
    },
    "network_external": false
  }
}

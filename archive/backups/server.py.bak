#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import re
import threading
import time
import traceback
import uuid
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.parse import parse_qs, urlparse

import yaml
from run_agent import AIAgent

HOST = os.getenv('HERMES_WEBUI_HOST', '127.0.0.1')
PORT = int(os.getenv('HERMES_WEBUI_PORT', '8787'))
HOME = Path.home()
CONFIG_PATH = Path(os.getenv('HERMES_CONFIG_PATH', str(HOME / '.hermes' / 'config.yaml')))
STATE_DIR = Path(os.getenv('HERMES_WEBUI_STATE_DIR', str(HOME / '.hermes' / 'webui-mvp')))
SESSION_DIR = STATE_DIR / 'sessions'
DEFAULT_WORKSPACE = Path(os.getenv('HERMES_WEBUI_DEFAULT_WORKSPACE', str(HOME / ".hermes" / "webui-mvp" / "test-workspace"))).expanduser().resolve()
DEFAULT_MODEL = os.getenv('HERMES_WEBUI_DEFAULT_MODEL', 'openai/gpt-5.4-mini')
MAX_FILE_BYTES = 200_000
LOCK = threading.Lock()
SESSIONS = {}

cfg = {}
if CONFIG_PATH.exists():
    try:
        cfg = yaml.safe_load(CONFIG_PATH.read_text()) or {}
    except Exception:
        cfg = {}
CLI_TOOLSETS = cfg.get('platform_toolsets', {}).get('cli', [
    'browser','clarify','code_execution','cronjob','delegation','file',
    'image_gen','memory','session_search','skills','terminal','todo',
    'tts','vision','web',
])

HTML = '''<!doctype html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Hermes Co-Work MVP</title>
<style>
:root{--bg:#111318;--panel:#171b22;--panel2:#202634;--line:#2c3340;--text:#e9e6df;--muted:#a4adbb;--accent:#d5b57a;--accent2:#7fb0ff;--code:#0d1117;font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,Segoe UI,sans-serif;}
*{box-sizing:border-box}body{margin:0;background:radial-gradient(circle at top,#161b24 0%,var(--bg) 55%);color:var(--text)}a{color:var(--accent2);text-decoration:none}
.app{display:grid;grid-template-columns:300px 1fr 360px;height:100vh}.sidebar,.rightbar,.chat{min-height:0}
.sidebar,.rightbar{background:rgba(13,16,21,.92);padding:18px;overflow:auto}.sidebar{border-right:1px solid var(--line)}.rightbar{border-left:1px solid var(--line)}
.chat{display:flex;flex-direction:column}.topbar{display:flex;justify-content:space-between;align-items:center;padding:16px 18px;border-bottom:1px solid var(--line);background:rgba(17,19,24,.88);backdrop-filter:blur(12px)}
.brand{display:flex;gap:12px;align-items:center}.logo{width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,#d5b57a,#8d6ee7)}.title{font-weight:700}.subtitle,.small,.hint{color:var(--muted);font-size:12px}.section{margin-bottom:16px}.section h4{margin:0 0 10px;text-transform:uppercase;letter-spacing:.12em;font-size:12px;color:var(--muted)}
.field,select,textarea,input{width:100%;border:1px solid var(--line);background:var(--panel2);color:var(--text);border-radius:12px;padding:10px 12px;outline:none;font-size:14px}textarea{resize:none;min-height:90px}
.btnrow,.toolbar{display:flex;gap:8px;flex-wrap:wrap}button{border:1px solid var(--line);background:linear-gradient(180deg,#232a36,#1b2029);color:var(--text);padding:10px 12px;border-radius:12px;cursor:pointer;font-size:13px}button.primary{background:linear-gradient(180deg,#d5b57a,#b98a45);color:#111;border-color:transparent;font-weight:700}
.pill{border:1px solid var(--line);background:var(--panel);padding:8px 10px;border-radius:999px;font-size:12px;color:var(--muted)}
.messages{flex:1;overflow:auto;padding:18px;display:flex;flex-direction:column;gap:16px}.msg{max-width:920px;border:1px solid var(--line);border-radius:16px;padding:14px 16px;background:var(--panel);box-shadow:0 12px 30px rgba(0,0,0,.26)}.msg.user{align-self:flex-end;background:linear-gradient(180deg,#222a36,#1b212b)}.msg.assistant{align-self:flex-start;background:linear-gradient(180deg,#171d27,#151a22)}.role{font-size:11px;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);margin-bottom:8px}.markdown{line-height:1.6;font-size:14px}.markdown p{margin:0 0 12px}.markdown ul{margin:8px 0 12px 22px}.markdown h1,.markdown h2,.markdown h3{margin:16px 0 8px}.markdown pre{background:var(--code);border:1px solid #273041;border-radius:12px;padding:12px;overflow:auto;white-space:pre-wrap;word-break:break-word}.composer{border-top:1px solid var(--line);padding:16px 18px;background:rgba(14,17,22,.96)}.composergrid{display:grid;grid-template-columns:1fr 160px 120px 140px;gap:10px;align-items:start}.filelist{display:flex;flex-direction:column;gap:4px;max-height:320px;overflow:auto}.fileitem{display:flex;justify-content:space-between;gap:10px;border-radius:10px;padding:8px 10px;cursor:pointer;border:1px solid transparent}.fileitem:hover,.fileitem.active{background:#232b39;border-color:var(--line)}.codeview{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:14px;min-height:280px}.codeview pre{margin:0;font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:13px;line-height:1.5;white-space:pre-wrap;word-break:break-word}.crumbs{font-size:12px;color:var(--muted);margin-bottom:8px;word-break:break-all}.divider{height:1px;background:var(--line);margin:14px 0}@media (max-width:1200px){.app{grid-template-columns:260px 1fr}.rightbar{display:none}.composergrid{grid-template-columns:1fr 140px 120px}}@media (max-width:820px){.app{grid-template-columns:1fr}.sidebar,.rightbar{display:none}}
</style></head><body>
<div class="app">
  <aside class="sidebar">
    <div class="section"><div class="title">Hermes Co-Work MVP</div><div class="subtitle">Claude-style workspace chat, simplified</div></div>
    <div class="section">
      <h4>Session</h4>
      <div class="hint">Session ID</div><input id="sessionId" class="field" type="text">
      <div style="height:8px"></div><div class="hint">Workspace root</div><input id="workspace" class="field" type="text">
      <div style="height:8px"></div><div class="hint">Model</div>
      <select id="model"><option value="openai/gpt-5.4-mini">GPT-5.4 Mini</option><option value="anthropic/claude-sonnet-4.6">Sonnet 4.6</option></select>
      <div style="height:10px"></div><div class="btnrow"><button class="primary" id="apply">Apply</button><button id="newChat">New chat</button><button id="refreshFiles">Refresh files</button></div>
    </div>
    <div class="section"><h4>Workspace</h4><div class="crumbs" id="crumbs"></div><div class="filelist" id="filetree"></div></div>
    <div class="section"><h4>Actions</h4><div class="btnrow"><button id="download">Download transcript</button><button id="clearPreview">Clear preview</button></div><div class="divider"></div><div class="small">Dark, dense, and calm. Good enough for v1.</div></div>
  </aside>
  <main class="chat">
    <div class="topbar"><div class="brand"><div class="logo"></div><div><div class="title" id="sessionTitle">Ready</div><div class="subtitle" id="sessionMeta">Load a session, then chat</div></div></div><div class="toolbar"><div class="pill" id="modelPill">GPT-5.4 Mini</div><div class="pill" id="workspacePill">Workspace</div></div></div>
    <div class="messages" id="messages"></div>
    <div class="composer"><div class="composergrid"><textarea id="message" placeholder="Ask Hermes anything, inspect files, plan, debug, or write. Shift+Enter for a newline."></textarea><button class="primary" id="send">Send</button><button id="stop">Stop</button><button id="copyLast">Copy last answer</button></div><div class="small" id="status">Tip: chat + file browsing + transcript download. That's the MVP.</div></div>
  </main>
  <aside class="rightbar"><div class="section"><h4>File preview</h4><div class="codeview"><div class="crumbs" id="previewPath">No file selected</div><pre id="preview">Click a file in the workspace list to view it here.</pre></div></div><div class="section"><h4>Notes</h4><div class="codeview markdown"><p><strong>MVP scope:</strong></p><ul><li>Claude-like workspace</li><li>Model switching</li><li>Workspace browsing</li><li>Markdown transcript download</li></ul><p>Hermes still does the heavy lifting.</p></div></div></aside>
</div>
<script>
const state={session:null,messages:[],entries:[],busy:false};
const $=id=>document.getElementById(id);const esc=s=>String(s??'').replace(/[&<>]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;'}[c]));
function md(text){let s=esc(text||'');s=s.replace(/```([\w+-]*)\n([\s\S]*?)```/g,(_,lang,code)=>`<pre><div class="small">${esc(lang)}</div>${esc(code)}</pre>`);s=s.replace(/`([^`]+)`/g,'<code>$1</code>');s=s.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>');s=s.replace(/^### (.+)$/gm,'<h3>$1</h3>').replace(/^## (.+)$/gm,'<h2>$1</h2>').replace(/^# (.+)$/gm,'<h1>$1</h1>');const lines=s.split('\n');let out=[],inList=false;for(const line of lines){if(/^(-|\*)\s+/.test(line)){if(!inList){out.push('<ul>');inList=true}out.push(`<li>${line.replace(/^(-|\*)\s+/,'')}</li>`)}else{if(inList){out.push('</ul>');inList=false}if(!line.trim()) out.push('<div style="height:4px"></div>'); else out.push(`<p>${line}</p>`)}}if(inList) out.push('</ul>');return out.join('')}
function setBusy(v,label){state.busy=v;$('status').textContent=label||(v?'Working...':'Ready')}
function sync(){if(!state.session)return;$('sessionId').value=state.session.session_id;$('workspace').value=state.session.workspace;$('model').value=state.session.model;$('sessionTitle').textContent=state.session.title||'Untitled';$('sessionMeta').textContent=`${state.session.message_count||state.messages.length||0} messages · ${state.session.workspace}`;$('modelPill').textContent=state.session.model.includes('sonnet')?'Sonnet 4.6':'GPT-5.4 Mini';$('workspacePill').textContent=state.session.workspace.split('/').slice(-2).join('/')||state.session.workspace;}
function renderMessages(){const box=$('messages');box.innerHTML='';for(const m of state.messages){if(!m||!m.role||m.role==='tool')continue;const el=document.createElement('div');el.className=`msg ${m.role}`;const role=document.createElement('div');role.className='role';role.textContent=m.role;const body=document.createElement('div');body.className='markdown';let content=m.content||'';if(Array.isArray(content)) content=content.map(p=>p.text||p.content||'').join('\n');body.innerHTML=md(String(content));el.appendChild(role);el.appendChild(body);box.appendChild(el);}box.scrollTop=box.scrollHeight}
function renderFiles(){const box=$('filetree');box.innerHTML='';$('crumbs').textContent=state.session?state.session.workspace:'';for(const item of state.entries){const row=document.createElement('div');row.className='fileitem';row.innerHTML=`<div><div>${item.type==='dir'?'📁':'📄'} ${esc(item.name)}</div><div class='small'>${esc(item.path)}</div></div><div class='small'>${item.type==='file'&&item.size?item.size+'b':''}</div>`;row.onclick=async()=>{if(item.type==='dir'){await loadDir(item.path);}else{await openFile(item.path);}};box.appendChild(row);}}
async function api(path, options={}){const res=await fetch(path,{headers:{'Content-Type':'application/json'},...options});if(!res.ok) throw new Error(await res.text());const ct=res.headers.get('content-type')||'';return ct.includes('application/json') ? res.json() : res.text()}
async function loadDir(path){const data=await api(`/api/list?session_id=${encodeURIComponent(state.session.session_id)}&path=${encodeURIComponent(path)}`);state.entries=data.entries||[];renderFiles()}
async function openFile(path){const data=await api(`/api/file?session_id=${encodeURIComponent(state.session.session_id)}&path=${encodeURIComponent(path)}`);$('previewPath').textContent=data.path;$('preview').textContent=data.content;setBusy(false,`Previewing ${data.path}`)}
async function saveSession(){const data=await api('/api/session/update',{method:'POST',body:JSON.stringify({session_id:state.session.session_id,workspace:$('workspace').value,model:$('model').value})});state.session=data.session;sync()}
function transcript(){const lines=[`# Hermes session ${state.session?.session_id||''}`,'',`Workspace: ${state.session?.workspace||''}`,`Model: ${state.session?.model||''}`,''];for(const m of state.messages){if(!m||m.role==='tool')continue;let c=m.content||'';if(Array.isArray(c)) c=c.map(p=>p.text||p.content||'').join('\n');lines.push(`## ${m.role}`,'',String(c).trim(),'');}return lines.join('\n')}
async function newSession(){const data=await api('/api/session/new',{method:'POST',body:JSON.stringify({workspace:$('workspace').value,model:$('model').value})});state.session=data.session;state.messages=state.session.messages||[];localStorage.setItem('hermes-webui-session',state.session.session_id);sync();await loadDir('.');renderMessages()}
async function loadSession(sessionId){const data=await api(`/api/session?session_id=${encodeURIComponent(sessionId)}`);state.session=data.session;state.messages=state.session.messages||[];sync();await loadDir('.');renderMessages()}
async function send(){const text=$('message').value.trim();if(!text||state.busy)return;$('message').value='';state.messages.push({role:'user',content:text});renderMessages();setBusy(true,'Hermes is thinking...');try{await saveSession();const data=await api('/api/chat',{method:'POST',body:JSON.stringify({session_id:state.session.session_id,message:text,model:$('model').value,workspace:$('workspace').value})});state.session=data.session;state.messages=state.session.messages||[];sync();await loadDir('.');renderMessages();setBusy(false,data.status||'Done')}catch(e){state.messages.push({role:'assistant',content:`**Error:** ${e.message}`});renderMessages();setBusy(false,'Error')}}
$('send').onclick=send;$('apply').onclick=async()=>{if(!state.session) await newSession(); else await saveSession(); await loadDir('.'); setBusy(false,'Updated')};$('newChat').onclick=async()=>{await newSession();$('message').focus()};$('refreshFiles').onclick=async()=>{if(state.session) await loadDir('.')};$('download').onclick=()=>{const blob=new Blob([transcript()],{type:'text/markdown'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=`hermes-session-${state.session?.session_id||'transcript'}.md`;a.click();URL.revokeObjectURL(a.href)};$('clearPreview').onclick=()=>{$('previewPath').textContent='No file selected';$('preview').textContent='Click a file in the workspace list to view it here.'};$('stop').onclick=()=>setBusy(false,'Stop is not wired in the MVP yet.');$('copyLast').onclick=async()=>{const last=[...state.messages].reverse().find(m=>m&&m.role==='assistant');if(!last) return;let c=last.content||'';if(Array.isArray(c)) c=c.map(p=>p.text||p.content||'').join('\n');await navigator.clipboard.writeText(String(c));setBusy(false,'Last answer copied.')};$('message').addEventListener('keydown',e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();send()}});(async()=>{const saved=localStorage.getItem('hermes-webui-session');if(saved){try{await loadSession(saved);return}catch(e){}}await newSession()})();
</script></body></html>
'''

def safe_resolve(root: Path, requested: str) -> Path:
    root = root.expanduser().resolve(); requested = (requested or '.').strip()
    candidate = root if requested in ('', '.') else (root / requested if not os.path.isabs(requested) else Path(requested)).expanduser().resolve()
    candidate.relative_to(root)
    return candidate

def j(handler, payload, status=200):
    raw = json.dumps(payload, ensure_ascii=False, indent=2).encode('utf-8')
    handler.send_response(status); handler.send_header('Content-Type','application/json; charset=utf-8'); handler.send_header('Content-Length', str(len(raw))); handler.send_header('Cache-Control','no-store'); handler.end_headers(); handler.wfile.write(raw)

def t(handler, payload, status=200, content_type='text/plain; charset=utf-8'):
    raw = payload.encode('utf-8'); handler.send_response(status); handler.send_header('Content-Type', content_type); handler.send_header('Content-Length', str(len(raw))); handler.send_header('Cache-Control','no-store'); handler.end_headers(); handler.wfile.write(raw)

def read_body(handler):
    length = int(handler.headers.get('Content-Length','0') or 0)
    return json.loads(handler.rfile.read(length) or b'{}') if length else {}

class Session:
    def __init__(self, session_id=None, title='Untitled', workspace=str(DEFAULT_WORKSPACE), model=DEFAULT_MODEL, messages=None, created_at=None, updated_at=None):
        self.session_id = session_id or uuid.uuid4().hex[:12]; self.title = title; self.workspace = str(Path(workspace).expanduser().resolve()); self.model = model; self.messages = messages or []; self.created_at = created_at or time.time(); self.updated_at = updated_at or time.time()
    @property
    def path(self): return SESSION_DIR / f'{self.session_id}.json'
    def save(self): self.updated_at = time.time(); self.path.write_text(json.dumps(self.__dict__, ensure_ascii=False, indent=2), encoding='utf-8')
    @classmethod
    def load(cls, sid):
        p = SESSION_DIR / f'{sid}.json'
        if not p.exists(): return None
        return cls(**json.loads(p.read_text(encoding='utf-8')))
    def compact(self): return {'session_id': self.session_id, 'title': self.title, 'workspace': self.workspace, 'model': self.model, 'message_count': len(self.messages), 'created_at': self.created_at, 'updated_at': self.updated_at}

def get_session(sid):
    if sid in SESSIONS: return SESSIONS[sid]
    s = Session.load(sid)
    if s: SESSIONS[sid] = s; return s
    raise KeyError(sid)

def new_session(workspace=None, model=None):
    s = Session(workspace=workspace or DEFAULT_WORKSPACE, model=model or DEFAULT_MODEL); SESSIONS[s.session_id] = s; s.save(); return s

def all_sessions():
    out = []
    for p in SESSION_DIR.glob('*.json'):
        try:
            s = Session.load(p.stem)
            if s: out.append(s)
        except Exception:
            pass
    for s in SESSIONS.values():
        if all(s.session_id != x.session_id for x in out): out.append(s)
    out.sort(key=lambda s: s.updated_at, reverse=True)
    return [s.compact() for s in out]

def list_dir(workspace: Path, rel='.'):
    target = safe_resolve(workspace, rel)
    if not target.exists() or not target.is_dir(): raise FileNotFoundError(rel)
    rows = []
    for item in sorted(target.iterdir(), key=lambda p: (not p.is_dir(), p.name.lower())):
        rows.append({'name': item.name, 'path': str(item.relative_to(workspace)), 'type': 'dir' if item.is_dir() else 'file', 'size': None if item.is_dir() else item.stat().st_size})
    return rows[:200]

def read_file(workspace: Path, rel):
    target = safe_resolve(workspace, rel)
    if not target.exists() or not target.is_file(): raise FileNotFoundError(rel)
    if target.stat().st_size > MAX_FILE_BYTES: raise ValueError(f'File too large: {target.stat().st_size} bytes')
    text = target.read_text(encoding='utf-8', errors='replace')
    return {'path': str(target.relative_to(workspace)), 'content': text, 'size': target.stat().st_size, 'lines': text.count('\n') + 1}

def title_from(messages, fallback='Untitled'):
    for m in messages:
        if m.get('role') == 'user':
            c = m.get('content','')
            if isinstance(c, list): c = '\n'.join((p.get('text') or '') for p in c if isinstance(p, dict))
            t = str(c).strip().replace('\n',' ')
            return t[:64] if t else fallback
    return fallback

class Handler(BaseHTTPRequestHandler):
    server_version = 'HermesCoWorkMVP/0.1'
    def log_message(self, fmt, *args): print('[webui]', fmt % args)
    def do_GET(self):
        try:
            parsed = urlparse(self.path)
            if parsed.path in ('/', '/index.html'): return t(self, HTML, content_type='text/html; charset=utf-8')
            if parsed.path == '/health': return j(self, {'status':'ok', 'sessions': len(SESSIONS)})
            if parsed.path == '/api/session':
                sid = parse_qs(parsed.query).get('session_id', [''])[0]
                if not sid:
                    s = new_session(); return j(self, {'session': s.compact() | {'messages': s.messages}})
                s = get_session(sid); return j(self, {'session': s.compact() | {'messages': s.messages}})
            if parsed.path == '/api/sessions': return j(self, {'sessions': all_sessions()})
            if parsed.path == '/api/list':
                qs = parse_qs(parsed.query); s = get_session(qs.get('session_id', [''])[0]); return j(self, {'entries': list_dir(Path(s.workspace), qs.get('path', ['.'])[0]), 'path': qs.get('path', ['.'])[0]})
            if parsed.path == '/api/file':
                qs = parse_qs(parsed.query); s = get_session(qs.get('session_id', [''])[0]); return j(self, read_file(Path(s.workspace), qs.get('path', [''])[0]))
            return j(self, {'error':'not found'}, status=404)
        except Exception as e:
            return j(self, {'error': str(e), 'trace': traceback.format_exc()}, status=500)
    def do_POST(self):
        try:
            parsed = urlparse(self.path); body = read_body(self)
            if parsed.path == '/api/session/new':
                s = new_session(workspace=body.get('workspace'), model=body.get('model')); return j(self, {'session': s.compact() | {'messages': s.messages}})
            if parsed.path == '/api/session/update':
                s = get_session(body['session_id']); s.workspace = str(Path(body.get('workspace', s.workspace)).expanduser().resolve()); s.model = body.get('model', s.model); s.save(); return j(self, {'session': s.compact() | {'messages': s.messages}})
            if parsed.path == '/api/chat':
                s = get_session(body['session_id']); msg = str(body.get('message', '')).strip()
                if not msg: return j(self, {'error':'empty message'}, status=400)
                workspace = Path(body.get('workspace') or s.workspace).expanduser().resolve(); s.workspace = str(workspace); s.model = body.get('model') or s.model
                old_cwd = os.environ.get('TERMINAL_CWD'); os.environ['TERMINAL_CWD'] = str(workspace)
                try:
                    with LOCK:
                        agent = AIAgent(model=s.model, platform='cli', quiet_mode=True, enabled_toolsets=CLI_TOOLSETS, session_id=s.session_id)
                        result = agent.run_conversation(user_message=msg, conversation_history=s.messages, session_id=s.session_id)
                finally:
                    if old_cwd is None: os.environ.pop('TERMINAL_CWD', None)
                    else: os.environ['TERMINAL_CWD'] = old_cwd
                s.messages = result.get('messages') or s.messages; s.title = title_from(s.messages, s.title); s.save()
                return j(self, {'answer': result.get('final_response') or '', 'status': 'done' if result.get('completed', True) else 'partial', 'session': s.compact() | {'messages': s.messages}, 'result': {k:v for k,v in result.items() if k != 'messages'}})
            return j(self, {'error':'not found'}, status=404)
        except Exception as e:
            return j(self, {'error': str(e), 'trace': traceback.format_exc()}, status=500)

def main():
    STATE_DIR.mkdir(parents=True, exist_ok=True); SESSION_DIR.mkdir(parents=True, exist_ok=True)
    httpd = ThreadingHTTPServer((HOST, PORT), Handler)
    print(f'Hermes Co-Work MVP listening on http://{HOST}:{PORT}')
    print(f'Default workspace: {DEFAULT_WORKSPACE}')
    print(f'Default model: {DEFAULT_MODEL}')
    httpd.serve_forever()

if __name__ == '__main__':
    main()

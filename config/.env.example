# ── Hermes WebUI ────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Docker: mount this as /app/config/.env or set HERMES_WEBUI_ENV=/path/to/.env

HERMES_HOME=~/.hermes
HERMES_WEBUI_HOST=127.0.0.1
HERMES_WEBUI_PORT=8787
HERMES_WEBUI_STATE_DIR=~/.hermes/webui
HERMES_WEBUI_DEFAULT_WORKSPACE=~/workspace
HERMES_WEBUI_PASSWORD=
HERMES_WEBUI_SKIP_ONBOARDING=false
HERMES_WEBUI_ONBOARDING_OPEN=false
HERMES_WEBUI_TLS_CERT=
HERMES_WEBUI_TLS_KEY=

# ── Agent ──────────────────────────────────────────────────────────────────────
HERMES_WEBUI_AGENT_DIR=~/.hermes/hermes-agent
HERMES_WEBUI_DEFAULT_MODEL=
HERMES_WEBUI_PYTHON=

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── Google ─────────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_SSE=true
GEMINI_MODEL=gemini-2.5-flash

# ── DeepSeek ──────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Azure OpenAI ───────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-06-01

# ── Mistral ───────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=

# ── Cohere ────────────────────────────────────────────────────────────────────
COHERE_API_KEY=

# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ── Fireworks ─────────────────────────────────────────────────────────────────
FIREWORKS_API_KEY=

# ── Together AI ────────────────────────────────────────────────────────────────
TOGETHER_API_KEY=

# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Ollama (local) ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── LM Studio (local) ─────────────────────────────────────────────────────────
LMSTUDIO_BASE_URL=http://localhost:1234

# ── Voyage AI ─────────────────────────────────────────────────────────────────
VOYAGEAI_API_KEY=

# ── HuggingFace ────────────────────────────────────────────────────────────────
HF_TOKEN=

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── MiniMax ───────────────────────────────────────────────────────────────────
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ── OpenAI人事 ( ZhiPu ) ───────────────────────────────────────────────────────
ZHIPUAI_API_KEY=

# ── Cloudflare Workers AI ──────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ── Grok (xAI) ────────────────────────────────────────────────────────────────
XAI_API_KEY=

# ── SambaNova ─────────────────────────────────────────────────────────────────
SAMBANOVA_API_KEY=

# ── Lepton ────────────────────────────────────────────────────────────────────
LEPTONAI_TOKEN=

# ── Hyperbolic ────────────────────────────────────────────────────────────────
HYPERBOLIC_API_KEY=

# ── Maritalk ──────────────────────────────────────────────────────────────────
MARITALK_API_KEY=

# ── Falcon (TII) ──────────────────────────────────────────────────────────────
FALCON_API_KEY=

# ── Livebot ───────────────────────────────────────────────────────────────────
LIVEBOT_API_KEY=

# ── Novita ────────────────────────────────────────────────────────────────────
NOVITA_API_KEY=

# ── DeepInfra ─────────────────────────────────────────────────────────────────
DEEPINFRA_API_KEY=

# ── Instill AI ────────────────────────────────────────────────────────────────
INSTILL_API_KEY=

# ── Titan (Amazon) ────────────────────────────────────────────────────────────
TITAN_Galore_API_KEY=

# ── Meta ───────────────────────────────────────────────────────────────────────
META_LLAMA_API_KEY=

# ── Alibaba (Qwen) ────────────────────────────────────────────────────────────
ALIBABA_API_KEY=

# ── Silicon Flow ──────────────────────────────────────────────────────────────
SILICONFLOW_API_KEY=

# ── Custom Provider ────────────────────────────────────────────────────────────
CUSTOM_MODELS_API_KEY=
CUSTOM_MODELS_BASE_URL=
CUSTOM_MODELS_ID=

# ── Agent / Gateway ────────────────────────────────────────────────────────────
HERMES_MODEL=
LLM_MODEL=
HERMES_CONFIG_PATH=
HERMES_SESSION_KEY=
HERMES_EXEC_ASK=
TERMINAL_CWD=
GATEWAY_ALLOW_ALL_USERS=true

# ── Telegram Bot ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# ── Discord ────────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# ── Slack ───────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── WhatsApp ───────────────────────────────────────────────────────────────────
WHATSAPP_SESSION_PATH=~/.hermes/whatsapp-session

# ── WeChat Work (WeCom) ─────────────────────────────────────────────────────────
WECOM_CORP_ID=
WECOM_CLIENT_SECRET=
WECOM_AGENT_ID=
WECOM_TOKEN=
WECOM_AES_KEY=

# ── n8n Webhook ────────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=
N8N_WEBHOOK_KEY=

# ── CamoFox Browser Automation ────────────────────────────────────────────────
# CamoFox provides persistent browser sessions with VNC for visual debugging.
# Image: jo-inc/camofox-browser
# Docs: https://github.com/nousresearch/hermes-agent/blob/master/tools/browser_camofox.py
CAMOFOX_PORT=9377
CAMOFOX_URL=http://localhost:9377

# ── Firecrawl Web Scraping ─────────────────────────────────────────────────────
# Firecrawl is used for web_search and web_extract tools.
# Get an API key at https://firecrawl.dev
FIRECRAWL_API_KEY=***
FIRECRAWL_API_URL=      # optional: for self-hosted Firecrawl

# ── Home Assistant ─────────────────────────────────────────────────────────────
HA_URL=http://homeassistant.local:8123
HA_TOKEN=***

# ── SSH / Terminal ─────────────────────────────────────────────────────────────
TERMINAL_SSH_HOST=
TERMINAL_SSH_PORT=22
TERMINAL_SSH_USER=
TERMINAL_SSH_KEY=
